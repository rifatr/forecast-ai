# WeatherAI upstream API
WAI_API_KEY=wai_your_key_here
WAI_BASE_URL=https://api.weather-ai.co
WAI_PLAN=free
WAI_MOCK=false
WAI_MOCK_TREES=true

# Redis (local or Upstash)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development

# Rate limiting (per IP)
THROTTLE_TTL=60000
THROTTLE_LIMIT=15

# Adaptive Caching (Quota Percentage)
ADAPTIVE_CACHE_THRESHOLD_WARNING=30
ADAPTIVE_CACHE_MULTIPLIER_WARNING=12
ADAPTIVE_CACHE_THRESHOLD_CRITICAL=10
ADAPTIVE_CACHE_MULTIPLIER_CRITICAL=144
ADAPTIVE_CACHE_THRESHOLD_EMERGENCY=2
ADAPTIVE_CACHE_MULTIPLIER_EMERGENCY=288
